# =============================================================
# ERPNext + HRMS + Print Designer + Additional Apps
# Environment Variables
# Image: custom-built with all apps (Dockerfile + apps.json)
# Domain: erpapps.kilebe.com
# =============================================================

# ── Image Configuration ───────────────────────────────────────
# Custom-built image with all apps baked in (see build-image.sh)
# After building, push to your registry and update these values
IMAGE_NAME=knimer/erpnext
VERSION=v15.custom
# Set to "never" when using a locally-built image on Dokploy
# Set to "always" if you push the image to Docker Hub / a registry
PULL_POLICY=never

# ── Site Configuration ────────────────────────────────────────
SITE_NAME=erpapps.kilebe.com
FRAPPE_SITE_NAME_HEADER=erpapps.kilebe.com

# ── Passwords (CHANGE THESE!) ────────────────────────────────
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Apps to Install ──────────────────────────────────────────
# Space-separated --install-app flags for each app you want on the site
# All apps below are already baked into the knimer/erpnext image
#
# Original apps:  erpnext, hrms, print_designer, payments
# New apps added:  webshop, builder, helpdesk, ksa_compliance (Saudi Arabia e-invoicing),
#                  frappe_attachment_preview, drive, frappe_whatsapp,
#                  insights, ecommerce_integrations
#
# NOTE: "ksa_compliance" is the Saudi Arabia ZATCA e-invoicing compliance app.
#       "frappe_whatsapp" is the community WhatsApp integration for Frappe.

INSTALL_APP_ARGS=--install-app erpnext --install-app hrms --install-app print_designer --install-app payments --install-app webshop --install-app builder --install-app helpdesk --install-app ksa_compliance --install-app frappe_attachment_preview --install-app drive --install-app frappe_whatsapp --install-app insights --install-app ecommerce_integrations

# ── Deployment Control ────────────────────────────────────────
# Set to 1 on FIRST deploy, then set to 0 after site is created
CONFIGURE=1
CREATE_SITE=1

# Set to 1 when you need to run migrations (e.g. after version update)
MIGRATE=0
